FROM python:3.12-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Slim deps: fastembed (ONNX) instead of torch/sentence-transformers, so the
# image and runtime memory stay small enough for modest hosting tiers.
COPY requirements-api.txt .
RUN pip install --no-cache-dir -r requirements-api.txt

COPY roqet ./roqet
COPY api.py ./api.py
COPY deploy/declarations.enriched.jsonl ./deploy/declarations.enriched.jsonl

# Serve with the fastembed (ONNX) embedder, on-disk Qdrant.
ENV ROQET_EMBEDDER=fastembed \
    QDRANT_PATH=/app/data/qdrant_storage \
    FASTEMBED_CACHE_PATH=/app/.cache/fastembed

# Bake the index into the image: downloads the ONNX embedding model (cached in
# the image) and builds the Qdrant store, so container start is fast and needs
# no network or external vector DB.
RUN python -m roqet.embedder \
    --input deploy/declarations.enriched.jsonl \
    --model fastembed \
    --reset

EXPOSE 8000
# Railway (and most PaaS) inject $PORT; fall back to 8000 locally.
CMD ["sh", "-c", "uvicorn roqet.api:app --host 0.0.0.0 --port ${PORT:-8000}"]
