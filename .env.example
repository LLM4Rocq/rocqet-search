# --- Frontend (Vercel / `npm run dev`) ---
# Base URL of the Roqet API. Locally this is http://localhost:8000.
# In production, set this to your deployed Railway API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Backend (only if NOT using the baked Dockerfile.api defaults) ---
# ROQET_EMBEDDER=local            # hash | local | openai (must match how the index was built)
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# QDRANT_URL=                     # set to use a remote Qdrant instead of the on-disk store
# QDRANT_API_KEY=
# CORS_ORIGINS=*                  # comma-separated; set to your Vercel domain in production
# OPENAI_API_KEY=                 # only when ROQET_EMBEDDER=openai
